{
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react$",
    "^react(.*)$",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@/components/(.*)$",
    "",
    "^@/hooks/(.*)$",
    "",
    "^@/pages/(.*)$",
    "",
    "^@/server/db(.*)$",
    "",
    "^@/server/trpc(.*)$",
    "",
    "^@/server/services/(.*)$",
    "",
    "^@/server/(.*)$",
    "",
    "^@/lib/(.*)$",
    "",
    "^@/utils/(.*)$",
    "",
    "^@/types/(.*)$",
    "",
    "(.*)env$",
    "",
    "^@/constants/(.*)$",
    "",
    "^@/(.*)$",
    "",
    "^(?!.*\\.css$)[./].*$",
    "",
    ".css$"
  ],
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 200,
  "semi": false
}
